# Copy to .env.local (dev) or .env.production.local (prod build)
# Leave empty to use same-origin backend (backend on same server)
# Set to your laptop's ngrok/tailscale/LAN URL to point to remote backend:
#   REACT_APP_API_URL=https://abc123.ngrok-free.app
#   REACT_APP_API_URL=http://100.64.0.5:8000
REACT_APP_API_URL=
