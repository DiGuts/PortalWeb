{
  "extends": ["react-app", "react-app/jest"],
  "rules": {
    "max-lines": ["warn", { "max": 500, "skipBlankLines": true, "skipComments": true }],
    "max-lines-per-function": ["warn", { "max": 200, "skipBlankLines": true, "skipComments": true, "IIFEs": false }],
    "complexity": ["warn", 15],
    "max-depth": ["warn", 4],
    "max-nested-callbacks": ["warn", 4],
    "no-console": ["warn", { "allow": ["warn", "error"] }]
  },
  "overrides": [
    {
      "files": ["src/**/*.{ts,tsx,js,jsx}"],
      "excludedFiles": ["src/**/*.test.*", "src/setupTests.ts", "src/reportWebVitals.ts"]
    }
  ]
}
