Options -MultiViews
RewriteEngine On

# Pass Authorization header to PHP (stripped by Apache on CGI/FastCGI by default)
RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]

# React SPA fallback — skip if file exists (lets .php files be served directly)
RewriteCond %{REQUEST_FILENAME} !-f
RewriteRule ^ index.html [QSA,L]
