{
  "name": "portalweb",
  "version": "0.1.0",
  "private": true,
  "homepage": "/public_html/portal_web",
  "dependencies": {
    "@azure/msal-browser": "^5.11.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/material": "^9.0.0",
    "@mui/x-date-pickers": "^9.0.4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^13.5.0",
    "@types/jest": "^27.5.2",
    "@types/node": "^16.18.126",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/sql.js": "^1.4.10",
    "clsx": "^2.1.1",
    "dayjs": "^1.11.20",
    "i18next": "^23.16.8",
    "lucide-react": "^1.6.0",
    "pdf-lib": "^1.17.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-i18next": "^14.1.3",
    "react-scripts": "5.0.1",
    "sql.js": "^1.14.1",
    "tailwind-merge": "^3.5.0",
    "typescript": "^4.9.5",
    "web-vitals": "^2.1.4"
  },
  "scripts": {
    "start": "react-scripts start",
    "backend": "cd backend && venv\\Scripts\\python -m uvicorn main:app --reload",
    "dev": "concurrently -n frontend,backend -c cyan,yellow \"npm start\" \"npm run backend\"",
    "build": "react-scripts build",
    "test": "react-scripts test",
    "eject": "react-scripts eject",
    "typecheck": "tsc --noEmit",
    "code-nav": "node scripts/code-nav.js",
    "code-nav:regen": "node scripts/code-nav.js --regen",
    "lint": "eslint src --ext .ts,.tsx,.js,.jsx --max-warnings=0",
    "lint:report": "eslint src --ext .ts,.tsx,.js,.jsx -f stylish",
    "audit:knip": "npx --yes knip --no-progress",
    "audit:madge": "npx --yes madge --circular --extensions ts,tsx src",
    "audit:madge:graph": "npx --yes madge --image deps.svg --extensions ts,tsx src",
    "audit:depcheck": "npx --yes depcheck",
    "audit:all": "npm run typecheck && npm run lint:report && npm run audit:knip && npm run audit:madge && npm run audit:depcheck"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.2.1",
    "jimp": "^1.6.0",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.1"
  }
}
